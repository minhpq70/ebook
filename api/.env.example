# ============================================================
# Ebook Platform API — Environment Variables
# Sao chép file này thành .env và điền giá trị thực
# ============================================================

# OpenAI
OPENAI_API_KEY=sk-proj-YOUR_API_KEY_HERE
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=4000

# Tuỳ chọn: Local LLM (Dành cho Qwen, Gemma qua LM Studio, Ollama, Google AI Studio)
# Bỏ comment và cấu hình nếu muốn dùng model riêng cho phần Hỏi đáp/Text:
# OPENAI_CHAT_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# OPENAI_CHAT_API_KEY=AIzaSy...
# OPENAI_CHAT_MODEL=gemma-4-31b-it

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key   # Service Role Key (có full access)
SUPABASE_ANON_KEY=your-anon-key      # Anon Key (cho frontend)

# RAG Config
RAG_CHUNK_SIZE=300            # tokens mỗi chunk (nhỏ hơn = precision cao hơn — tối ưu tiếng Việt)
RAG_CHUNK_OVERLAP=80          # tokens overlap (lớn hơn = giữ context tốt hơn)
RAG_TOP_K=5                   # số chunks trả về sau reranking
RAG_VECTOR_WEIGHT=0.7         # weight cho vector search trong hybrid
RAG_FTS_WEIGHT=0.3            # weight cho full-text search

# App
APP_ENV=development
APP_CORS_ORIGINS=http://localhost:3000

# Auth — BẮT BUỘC: JWT Secret phải có ít nhất 32 ký tự
# Tạo bằng: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
